<?xml version="1.0" encoding="UTF-8"?>
<con:soapui-project
    xmlns:con="http://eviware.com/soapui/config"
    id="sample-project-001"
    name="Public API Test Suite"
    soapui-version="5.7.0"
    abortOnError="false"
    runType="SEQUENTIAL"
    resourceRoot=""
    activeEnvironment="DEV">

  <con:settings/>

  <!-- ═══════════════════════════════════════════════════
       Project-level properties (default values)
       Override per environment below via <con:environments>
  ═══════════════════════════════════════════════════ -->
  <con:properties>
    <con:property>
      <con:name>baseUrl</con:name>
      <con:value>https://jsonplaceholder.typicode.com</con:value>
    </con:property>
    <con:property>
      <con:name>apiVersion</con:name>
      <con:value>v1</con:value>
    </con:property>
    <con:property>
      <con:name>authToken</con:name>
      <con:value>dev-token-placeholder</con:value>
    </con:property>
  </con:properties>

  <!-- ═══════════════════════════════════════════════════
       Environments: DEV and QA
       Switch active env from the ReadyAPI toolbar
  ═══════════════════════════════════════════════════ -->
  <con:environments>

    <con:environment name="DEV">
      <con:properties>
        <con:property>
          <con:name>baseUrl</con:name>
          <con:value>https://jsonplaceholder.typicode.com</con:value>
        </con:property>
        <con:property>
          <con:name>apiVersion</con:name>
          <con:value>v1</con:value>
        </con:property>
        <con:property>
          <con:name>authToken</con:name>
          <con:value>dev-token-placeholder</con:value>
        </con:property>
        <con:property>
          <con:name>userId</con:name>
          <con:value>1</con:value>
        </con:property>
        <con:property>
          <con:name>postId</con:name>
          <con:value>1</con:value>
        </con:property>
      </con:properties>
    </con:environment>

    <con:environment name="QA">
      <con:properties>
        <con:property>
          <con:name>baseUrl</con:name>
          <con:value>https://jsonplaceholder.typicode.com</con:value>
        </con:property>
        <con:property>
          <con:name>apiVersion</con:name>
          <con:value>v1</con:value>
        </con:property>
        <con:property>
          <con:name>authToken</con:name>
          <con:value>qa-token-placeholder</con:value>
        </con:property>
        <con:property>
          <con:name>userId</con:name>
          <con:value>2</con:value>
        </con:property>
        <con:property>
          <con:name>postId</con:name>
          <con:value>5</con:value>
        </con:property>
      </con:properties>
    </con:environment>

  </con:environments>

  <!-- ═══════════════════════════════════════════════════
       Test Suite 1: Posts API
       Endpoints use ${#Project#baseUrl} — resolved at
       runtime from the active environment.
  ═══════════════════════════════════════════════════ -->
  <con:testSuite name="Posts API" runType="SEQUENTIAL">
    <con:settings/>

    <!-- Test Case: Read Operations -->
    <con:testCase name="Read Operations" failOnError="true" keepSession="false">
      <con:settings/>

      <con:testStep type="httprequest" name="Get All Posts">
        <con:settings/>
        <con:config>
          <con:request id="req-001" name="Get All Posts">
            <con:endpoint>${#Project#baseUrl}/posts</con:endpoint>
            <con:method>GET</con:method>
            <con:headers>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:assertion type="Valid HTTP Status Codes" id="assert-001-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-001-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Count" id="assert-001-count" name="Array Is Not Empty">
              <con:configuration>
                <con:path>$</con:path>
                <con:expectedContent>0</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-001-id" name="First Item Has id">
              <con:configuration>
                <con:path>$[0].id</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-001-title" name="First Item Has title">
              <con:configuration>
                <con:path>$[0].title</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

      <con:testStep type="httprequest" name="Get Post By ID">
        <con:settings/>
        <con:config>
          <con:request id="req-002" name="Get Post By ID">
            <con:endpoint>${#Project#baseUrl}/posts/${#Project#postId}</con:endpoint>
            <con:method>GET</con:method>
            <con:headers>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:assertion type="Valid HTTP Status Codes" id="assert-002-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-002-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-002-id" name="Post ID Matches">
              <con:configuration>
                <con:path>$.id</con:path>
                <con:expectedContent>${#Project#postId}</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-002-title" name="Has title Field">
              <con:configuration>
                <con:path>$.title</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-002-body" name="Has body Field">
              <con:configuration>
                <con:path>$.body</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-002-userId" name="Has userId Field">
              <con:configuration>
                <con:path>$.userId</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

      <con:testStep type="httprequest" name="Get Posts By User">
        <con:settings/>
        <con:config>
          <con:request id="req-003" name="Get Posts By User">
            <con:endpoint>${#Project#baseUrl}/posts?userId=${#Project#userId}</con:endpoint>
            <con:method>GET</con:method>
            <con:headers>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:assertion type="Valid HTTP Status Codes" id="assert-003-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-003-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Count" id="assert-003-count" name="Returns Posts For User">
              <con:configuration>
                <con:path>$</con:path>
                <con:expectedContent>0</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-003-userId" name="All Posts Belong To User">
              <con:configuration>
                <con:path>$[0].userId</con:path>
                <con:expectedContent>${#Project#userId}</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

    </con:testCase>

    <!-- Test Case: Write Operations -->
    <con:testCase name="Write Operations" failOnError="true" keepSession="false">
      <con:settings/>

      <con:testStep type="httprequest" name="Create Post">
        <con:settings/>
        <con:config>
          <con:request id="req-004" name="Create Post">
            <con:endpoint>${#Project#baseUrl}/posts</con:endpoint>
            <con:method>POST</con:method>
            <con:headers>
              <con:entry key="Content-Type" value="application/json"/>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:requestContent>{"title": "foo", "body": "bar", "userId": ${#Project#userId}}</con:requestContent>
            <con:assertion type="Valid HTTP Status Codes" id="assert-004-status" name="Status 201 Created">
              <con:configuration>
                <con:codes>201</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-004-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-004-id" name="Response Has id">
              <con:configuration>
                <con:path>$.id</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-004-title" name="Title Matches Request">
              <con:configuration>
                <con:path>$.title</con:path>
                <con:expectedContent>foo</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-004-body" name="Body Matches Request">
              <con:configuration>
                <con:path>$.body</con:path>
                <con:expectedContent>bar</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-004-userId" name="UserId Matches Request">
              <con:configuration>
                <con:path>$.userId</con:path>
                <con:expectedContent>${#Project#userId}</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

      <con:testStep type="httprequest" name="Update Post">
        <con:settings/>
        <con:config>
          <con:request id="req-005" name="Update Post">
            <con:endpoint>${#Project#baseUrl}/posts/${#Project#postId}</con:endpoint>
            <con:method>PUT</con:method>
            <con:headers>
              <con:entry key="Content-Type" value="application/json"/>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:requestContent>{"id": ${#Project#postId}, "title": "updated title", "body": "updated body", "userId": ${#Project#userId}}</con:requestContent>
            <con:assertion type="Valid HTTP Status Codes" id="assert-005-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-005-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-005-id" name="Post ID Matches">
              <con:configuration>
                <con:path>$.id</con:path>
                <con:expectedContent>${#Project#postId}</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-005-title" name="Title Is Updated">
              <con:configuration>
                <con:path>$.title</con:path>
                <con:expectedContent>updated title</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-005-body" name="Body Is Updated">
              <con:configuration>
                <con:path>$.body</con:path>
                <con:expectedContent>updated body</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

      <con:testStep type="httprequest" name="Patch Post Title">
        <con:settings/>
        <con:config>
          <con:request id="req-006" name="Patch Post Title">
            <con:endpoint>${#Project#baseUrl}/posts/${#Project#postId}</con:endpoint>
            <con:method>PATCH</con:method>
            <con:headers>
              <con:entry key="Content-Type" value="application/json"/>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:requestContent>{"title": "patched title"}</con:requestContent>
            <con:assertion type="Valid HTTP Status Codes" id="assert-006-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-006-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-006-title" name="Title Is Patched">
              <con:configuration>
                <con:path>$.title</con:path>
                <con:expectedContent>patched title</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-006-id" name="Response Has id">
              <con:configuration>
                <con:path>$.id</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

      <con:testStep type="httprequest" name="Delete Post">
        <con:settings/>
        <con:config>
          <con:request id="req-007" name="Delete Post">
            <con:endpoint>${#Project#baseUrl}/posts/${#Project#postId}</con:endpoint>
            <con:method>DELETE</con:method>
            <con:headers>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:assertion type="Valid HTTP Status Codes" id="assert-007-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-007-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Simple Contains" id="assert-007-body" name="Response Body Is Empty Object">
              <con:configuration>
                <con:token>{}</con:token>
                <con:ignoreCase>false</con:ignoreCase>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

    </con:testCase>
  </con:testSuite>

  <!-- ═══════════════════════════════════════════════════
       Test Suite 2: Users API
  ═══════════════════════════════════════════════════ -->
  <con:testSuite name="Users API" runType="SEQUENTIAL">
    <con:settings/>

    <con:testCase name="User Queries" failOnError="true" keepSession="false">
      <con:settings/>

      <con:testStep type="httprequest" name="Get All Users">
        <con:settings/>
        <con:config>
          <con:request id="req-008" name="Get All Users">
            <con:endpoint>${#Project#baseUrl}/users</con:endpoint>
            <con:method>GET</con:method>
            <con:headers>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:assertion type="Valid HTTP Status Codes" id="assert-008-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-008-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Count" id="assert-008-count" name="Array Is Not Empty">
              <con:configuration>
                <con:path>$</con:path>
                <con:expectedContent>0</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-008-id" name="First User Has id">
              <con:configuration>
                <con:path>$[0].id</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-008-email" name="First User Has email">
              <con:configuration>
                <con:path>$[0].email</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

      <con:testStep type="httprequest" name="Get User By ID">
        <con:settings/>
        <con:config>
          <con:request id="req-009" name="Get User By ID">
            <con:endpoint>${#Project#baseUrl}/users/${#Project#userId}</con:endpoint>
            <con:method>GET</con:method>
            <con:headers>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:assertion type="Valid HTTP Status Codes" id="assert-009-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-009-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-009-id" name="User ID Matches">
              <con:configuration>
                <con:path>$.id</con:path>
                <con:expectedContent>${#Project#userId}</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-009-name" name="Has name Field">
              <con:configuration>
                <con:path>$.name</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-009-email" name="Has email Field">
              <con:configuration>
                <con:path>$.email</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-009-username" name="Has username Field">
              <con:configuration>
                <con:path>$.username</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

      <con:testStep type="httprequest" name="Get Todos For User">
        <con:settings/>
        <con:config>
          <con:request id="req-010" name="Get Todos For User">
            <con:endpoint>${#Project#baseUrl}/todos?userId=${#Project#userId}&amp;completed=false</con:endpoint>
            <con:method>GET</con:method>
            <con:headers>
              <con:entry key="Accept" value="application/json"/>
              <con:entry key="Authorization" value="Bearer ${#Project#authToken}"/>
            </con:headers>
            <con:assertion type="Valid HTTP Status Codes" id="assert-010-status" name="Status 200 OK">
              <con:configuration>
                <con:codes>200</con:codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="Response SLA" id="assert-010-sla" name="Response Time &lt; 5s">
              <con:configuration>
                <con:sla>5000</con:sla>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Count" id="assert-010-count" name="Returns Todos">
              <con:configuration>
                <con:path>$</con:path>
                <con:expectedContent>0</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="assert-010-completed" name="Todos Are Not Completed">
              <con:configuration>
                <con:path>$[0].completed</con:path>
                <con:expectedContent>false</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
                <con:ignoreNamspaceDifferences>false</con:ignoreNamspaceDifferences>
                <con:ignoreComments>false</con:ignoreComments>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Existence Match" id="assert-010-title" name="Has title Field">
              <con:configuration>
                <con:path>$[0].title</con:path>
                <con:expectedContent>true</con:expectedContent>
                <con:allowWildcards>false</con:allowWildcards>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>

    </con:testCase>
  </con:testSuite>

  <!-- Required project-level containers -->
